# UUID identifying the Proxmox node this container belongs to
NODE_ID=

# Positive integer — VMID of this container
VMID=

# HTTP base URL of the control plane
CONTROL_PLANE_URL=http://localhost:3000

# Shared secret — must match AGENT_SECRET in control plane .env (min 32 chars)
AGENT_SECRET=

# Reported hostname (optional — defaults to os.hostname())
# HOSTNAME=

# Heartbeat frequency in ms (default: 10000)
# HEARTBEAT_INTERVAL_MS=10000

# Delay before reconnect attempts in ms (default: 5000)
# RECONNECT_DELAY_MS=5000

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info
