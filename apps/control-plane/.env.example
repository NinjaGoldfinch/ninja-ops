# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://ninja:ninja@localhost:5432/ninja_ops

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_64_hex_chars
JWT_EXPIRY=24h

# ── Encryption (AES-256-GCM for secrets at rest) ──────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=change_me_32_bytes_as_64_hex_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agent auth ────────────────────────────────────────────────────────────
# Shared secret agents use to register. Generate same as JWT_SECRET.
AGENT_SECRET=change_me_64_hex_chars
AGENT_JWT_EXPIRY=7d

# ── GitHub webhooks ───────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=change_me

# ── Agent deployment ──────────────────────────────────────────────────────
# URL of this control plane, reachable from inside provisioned LXC containers.
# Optional — if omitted the control plane auto-detects its LAN IP at deploy time.
# Override in production, e.g. https://ninja-ops.example.com
# CONTROL_PLANE_URL=http://192.168.1.x:3000

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated origins. Leave empty to disable CORS (same-origin in prod).
CORS_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
