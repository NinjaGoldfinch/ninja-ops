# UUID of the Proxmox node this container belongs to
NODE_ID=

# VMID of this container
VMID=

# HTTP base URL of the control plane
CONTROL_PLANE_URL=http://localhost:3000

# Must match AGENT_SECRET in control-plane env
AGENT_SECRET=

# Comma-separated systemd units to tail (in addition to ninja-agent.service)
# Example: myapp.service,nginx.service
LOG_UNITS=

# Set to true to also tail system-level journald events
LOG_SYSTEM=false

# Optional tuning
# HEARTBEAT_INTERVAL_MS=15000
# RECONNECT_DELAY_MS=5000
# LOG_LEVEL=info
